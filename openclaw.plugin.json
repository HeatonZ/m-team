{
  "id": "m-team",
  "name": "M-Team Natural Language Collaboration",
  "version": "2026.5.12-3",
  "description": "Natural-language closed-loop task collaboration plugin for OpenClaw",
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "workspaceRoot": {
        "type": "string",
        "description": "Workspace root directory"
      },
      "executors": {
        "type": "array",
        "description": "Executor agent IDs that receive heartbeat claim guidance",
        "items": {
          "type": "string"
        },
        "default": [
          "maker",
          "fixer",
          "scholar",
          "captain"
        ]
      },
      "notifications": {
        "type": "array",
        "description": "Notification routing configuration",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "provider": {
              "type": "string",
              "enum": [
                "feishu",
                "discord"
              ],
              "description": "Notification provider"
            },
            "appId": {
              "type": "string",
              "description": "Feishu bot app_id (provider=feishu)"
            },
            "appSecret": {
              "type": "string",
              "description": "Feishu bot app_secret (provider=feishu)"
            },
            "groupId": {
              "type": "string",
              "description": "Feishu group chat_id"
            },
            "channelId": {
              "type": "string",
              "description": "Discord channel ID (provider=discord)"
            },
            "discordToken": {
              "type": "string",
              "description": "Discord bot token (provider=discord)"
            },
            "agents": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "agent IDs to notify"
            }
          },
          "required": [
            "provider",
            "agents"
          ]
        }
      },
      "publishers": {
        "type": "array",
        "description": "Publisher agent IDs that receive acceptance guidance",
        "items": {
          "type": "string"
        }
      },
      "claimRouting": {
        "type": "object",
        "description": "Deterministic claim routing by taskType",
        "additionalProperties": false,
        "properties": {
          "taskTypeAgents": {
            "type": "object",
            "description": "taskType -> allowed agentId list",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "denyUnroutedTaskTypes": {
            "type": "boolean",
            "description": "When true, task types without explicit route cannot be claimed (general remains allowed by default)"
          }
        }
      }
    }
  },
  "skills": [
    "./skills/m-team-publisher",
    "./skills/m-team-executor"
  ],
  "contracts": {
    "tools": [
      "mteam_publish_task",
      "mteam_claim_task",
      "mteam_next_task",
      "mteam_relinquish_task",
      "mteam_get_task",
      "mteam_get_pending",
      "mteam_cancel_task",
      "mteam_get_agent_active",
      "mteam_get_all_tasks",
      "mteam_close_task",
      "mteam_reject_task"
    ]
  }
}
