{
  "id": "m-team",
  "name": "M-Team 去中心化任务池",
  "version": "2026.5.8-1",
  "description": "去中心化任务池协作插件 — 多Agent任务分发与执行",
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "workspaceRoot": {
        "type": "string",
        "description": "工作空间根目录"
      },
      "executors": {
        "type": "array",
        "description": "Executor agent 列表（会收到心跳注入的 mteam 指令）",
        "items": {
          "type": "string"
        },
        "default": [
          "maker",
          "fixer",
          "scholar",
          "captain"
        ]
      },
      "notifications": {
        "type": "array",
        "description": "任务完成通知配置",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "provider": {
              "type": "string",
              "enum": [
                "feishu",
                "discord"
              ],
              "description": "通知渠道"
            },
            "appId": {
              "type": "string",
              "description": "飞书机器人的 app_id（provider=feishu 时使用）"
            },
            "appSecret": {
              "type": "string",
              "description": "飞书机器人的 app_secret（provider=feishu 时使用）"
            },
            "groupId": {
              "type": "string",
              "description": "飞书群 ID (chat_id)"
            },
            "channelId": {
              "type": "string",
              "description": "Discord 频道 ID (provider=discord 时使用)"
            },
            "agents": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "需要通知的 agentId 列表"
            }
          },
          "required": [
            "provider",
            "agents"
          ]
        }
      },
      "publishers": {
        "type": "array",
        "description": "Publisher agent 列表（会收到心跳注入的验收指令）",
        "items": {
          "type": "string"
        }
      }
    }
  },
  "skills": [
    "./skills/m-team-publisher",
    "./skills/m-team-executor"
  ],
  "contracts": {
    "tools": [
      "mteam_publish_task",
      "mteam_claim_task",
      "mteam_relinquish_task",
      "mteam_get_task",
      "mteam_get_pending",
      "mteam_cancel_task",
      "mteam_get_agent_active",
      "mteam_get_all_tasks",
      "mteam_close_task",
      "mteam_reject_task"
    ]
  }
}