{
  "name": "m-team",
  "version": "0.2.2",
  "description": "去中心化任务池协作插件 — 多Agent任务分发与执行",
  "type": "module",
  "main": "dist/index.js",
  "author": "郑尚丰",
  "license": "MIT",
  "keywords": [
    "openclaw",
    "multi-agent",
    "task-queue",
    "collaboration"
  ],
  "openclaw": {
    "hooks": [],
    "extensions": [
      "./dist/index.js"
    ],
    "skills": [
      "./skills"
    ],
    "install": {
      "localPath": "./",
      "defaultChoice": "local"
    },
    "compat": {
      "pluginApi": ">=2026.4.22"
    },
    "build": {
      "openclawVersion": "2026.4.22"
    }
  },
  "scripts": {
    "build": "esbuild ./src/index.ts --bundle --platform=node --outdir=dist --format=cjs --external:node:* --external:openclaw --external:openclaw/plugin-sdk --external:better-sqlite3",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "esbuild": "^0.24.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  }
}
