{
  "name": "m-team",
  "version": "0.3.9",
  "description": "去中心化任务池协作插件 — 多Agent任务分发与执行",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./pool/db": {
      "import": "./src/pool/db.ts",
      "types": "./src/pool/db.ts"
    },
    "./pool": {
      "import": "./src/pool/index.ts",
      "types": "./src/pool/index.ts"
    },
    "./schema/task": {
      "import": "./src/schema/task.ts",
      "types": "./src/schema/task.ts"
    }
  },
  "author": "郑尚丰",
  "license": "MIT",
  "keywords": [
    "openclaw",
    "multi-agent",
    "task-queue",
    "collaboration"
  ],
  "openclaw": {
    "hooks": [],
    "extensions": [
      "./dist/index.js"
    ],
    "skills": [
      "./skills"
    ],
    "install": {
      "localPath": "./",
      "defaultChoice": "local"
    },
    "compat": {
      "pluginApi": ">=2026.4.22"
    },
    "build": {
      "openclawVersion": "2026.4.22"
    }
  },
  "scripts": {
    "build": "npm run build:plugin && npm run build:dashboard",
    "build:plugin": "esbuild ./src/index.ts --bundle --platform=node --outdir=dist --format=cjs --external:node:* --external:openclaw --external:openclaw/plugin-sdk --external:better-sqlite3",
    "build:dashboard": "npm run build --prefix dashboard && node scripts/bundle-dashboard-server.mjs",
    "postinstall": "npm run build",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "esbuild": "^0.24.0",
    "nock": "^14.0.14",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "tsx": "^4.21.0"
  }
}
